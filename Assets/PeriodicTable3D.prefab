  nameText: {fileID: 463843343845163980}
  data:
    name: Thorium
    category: 'actinide '
    spectral_img: 
    xpos: 4
    ypos: 9
    named_by: 
    density: 11.724
    color: 
    molar_heat: 26.23
    symbol: Th
    discovered_by: "J\xF6ns Jakob Berzelius"
    appearance: silvery, often with black tarnish
    atomic_mass: 232.03773
    melt: 2023
    number: 90
    source: https://en.wikipedia.org/wiki/Thorium
    period: 1
    phase: Solid
    summary: "Thorium is a chemical element with symbol Th and atomic number 90.
      A radioactive actinide metal, thorium is one of only two significantly radioactive
      elements that still occur naturally in large quantities as a primordial element
      (the other being uranium). It was discovered in 1828 by the Norwegian Reverend
      and amateur mineralogist Morten Thrane Esmark and identified by the Swedish
      chemist J\xF6ns Jakob Berzelius, who named it after Thor, the Norse god of
      thunder."
    boil: 5061
