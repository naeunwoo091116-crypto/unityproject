  data:
    name: Phosphorus
    category: 'polyatomic nonmetal '
    spectral_img: 
    xpos: 15
    ypos: 3
    named_by: 
    density: 0
    color: 
    molar_heat: 23.824
    symbol: P
    discovered_by: Hennig Brand
    appearance: colourless, waxy white, yellow, scarlet, red, violet, black
    atomic_mass: 30.973763
    melt: 0
    number: 15
    source: https://en.wikipedia.org/wiki/Phosphorus
    period: 1
    phase: Solid
    summary: "Phosphorus is a chemical element with symbol P and atomic number 15.
      As an element, phosphorus exists in two major forms\u2014white phosphorus and
      red phosphorus\u2014but due to its high reactivity, phosphorus is never found
      as a free element on Earth. Instead phosphorus-containing minerals are almost
      always present in their maximally oxidised state, as inorganic phosphate rocks."
    boil: 0
