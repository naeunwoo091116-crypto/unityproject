  nameText: {fileID: 8411918182981846226}
  data:
    name: Osmium
    category: 'transition metal '
    spectral_img: 
    xpos: 8
    ypos: 6
    named_by: 
    density: 22.59
    color: 
    molar_heat: 24.7
    symbol: Os
