  data:
    name: Gallium
    category: 'post-transition metal '
    spectral_img: 
    xpos: 13
    ypos: 4
    named_by: 
    density: 5.91
    color: 
    molar_heat: 25.86
    symbol: Ga
    discovered_by: Lecoq de Boisbaudran
