  data:
    name: Hafnium
    category: 'transition metal '
    spectral_img: https://en.wikipedia.org/wiki/File:Hafnium_spectrum_visible.png
    xpos: 4
    ypos: 6
    named_by: 
    density: 13.31
    color: 
    molar_heat: 25.73
    symbol: Hf
    discovered_by: Dirk Coster
