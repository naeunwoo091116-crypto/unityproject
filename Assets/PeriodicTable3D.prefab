  data:
    name: Antimony
    category: 'metalloid '
    spectral_img: 
    xpos: 15
    ypos: 5
    named_by: 
    density: 6.697
    color: 
    molar_heat: 25.23
    symbol: Sb
    discovered_by: unknown, before 3000 BC
    appearance: silvery lustrous gray
    atomic_mass: 121.7601
    melt: 903.78
    number: 51
    source: https://en.wikipedia.org/wiki/Antimony
    period: 1
    phase: Solid
    summary: 'Antimony is a chemical element with symbol Sb (from Latin: stibium)
      and atomic number 51. A lustrous gray metalloid, it is found in nature mainly
      as the sulfide mineral stibnite (Sb2S3). Antimony compounds have been known
      since ancient times and were used for cosmetics; metallic antimony was also
      known, but it was erroneously identified as lead upon its discovery.'
    boil: 1908
