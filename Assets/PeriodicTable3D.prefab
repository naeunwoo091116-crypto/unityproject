  data:
    name: Fluorine
    category: 'diatomic nonmetal '
    spectral_img: 
    xpos: 17
    ypos: 2
    named_by: Humphry Davy
    density: 1.696
    color: 
    molar_heat: 0
    symbol: F
    discovered_by: "Andr\xE9-Marie Amp\xE8re"
