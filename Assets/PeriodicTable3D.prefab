  data:
    name: Ununseptium
    category: 'metalloid '
    spectral_img: 
    xpos: 17
    ypos: 7
    named_by: 
    density: 7.17
    color: 
    molar_heat: 0
    symbol: Uus
    discovered_by: Joint Institute for Nuclear Research
    appearance: 
    atomic_mass: 294
    melt: 623823
    number: 117
    source: https://en.wikipedia.org/wiki/Ununseptium
    period: 1
    phase: Solid
    summary: 'Ununseptium is a superheavy artificial chemical element with an atomic
      number of 117 and a temporary symbol of Uus. Also known as eka-astatine or
      element 117, it is the second-heaviest known element and penultimate element
      of the 7th period of the periodic table. As of 2016, fifteen ununseptium atoms
      have been observed: six when it was first synthesized in 2010, seven in 2012,
      and two in 2014.'
    boil: 883
