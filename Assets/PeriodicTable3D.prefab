  data:
    name: Actinium
    category: 'actinide '
    spectral_img: 
    xpos: 3
    ypos: 9
    named_by: 
    density: 10
    color: 
    molar_heat: 27.2
    symbol: Ac
    discovered_by: Friedrich Oskar Giesel
    appearance: 
    atomic_mass: 227
